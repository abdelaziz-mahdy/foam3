{
  "$schema": "https://raw.githubusercontent.com/nicolo-ribaudo/tc39-proposal-tagged-template-literal-grammars/master/vscode-extension/schema.json",
  "scopeName": "foam.js.injection",
  "injectionSelector": "L:source.js",
  "patterns": [
    {
      "comment": "Match javaCode: ` and inject Java highlighting. We need to consume the key + backtick before the JS grammar's template literal rule does.",
      "name": "meta.foam.java-block.js",
      "begin": "(?<=[:\\s])(javaCode|javaPreSet|javaPostSet|javaFactory|javaGetter|javaSetter)(\\s*:\\s*)(`)",
      "beginCaptures": {
        "1": { "name": "support.type.property-name.foam" },
        "2": { "name": "punctuation.separator.key-value.js" },
        "3": { "name": "punctuation.definition.string.template.begin.js" }
      },
      "end": "(`)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.string.template.end.js" }
      },
      "contentName": "meta.embedded.block.java",
      "patterns": [
        { "include": "source.java" }
      ]
    }
  ]
}
