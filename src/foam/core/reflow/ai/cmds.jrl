p({
  "class":"foam.core.reflow.ai.LLMCommand",
  "id": "llm",
  "description": "Issue a direct LLM query."
})
p({
  "class":"foam.core.reflow.ai.AgentCommand",
  "id": "agent",
  "dryRun": false,
  "description": "Issue a request to an LLM agent to execute FLOW commands."
})
p({
  "class":"foam.core.reflow.ai.AgentCommand",
  "id": "?",
  "dryRun": false,
  "description": "Issue a request to an LLM agent to execute FLOW commands."
})
p({
  "class":"foam.core.reflow.ai.AgentCommand",
  "id": "??",
  "dryRun": true,
  "description": "Issue a request to an LLM agent to execute FLOW commands."
})
p({
  "class":"foam.core.reflow.ai.AskCommand",
  "id": "ask",
  "description": "Allow LLMs to ask questions and get responses.",
  "hidden": true
})
p({
  "class":"foam.core.reflow.cmd.Command",
  "id": "propose",
  "description": "Propose a command for execution",
  "script": "addValue(foam.core.reflow.ai.Propose.create({command: args.join(' ')}, this));"
})
